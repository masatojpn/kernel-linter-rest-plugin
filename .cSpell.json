{
  "version": "0.1",
  "words": [
    "teamlibrary",
    "UNALLOWED",
    "Renderable",
    "Inspectable",
    "evenodd",
    "labelledby"
  ],
  "ignorePaths": [
    ".cSpell.json",
    "package-lock.json",
    "pnpm-lock.yaml",
    "node_modules"
  ],
  "patterns": [
    {
      "name": "allCapsWords",
      "pattern": "/\\b[A-Z][A-Z0-9_]{1,}\\b/g"
    },
    {
      "name": "uuidLike",
      "pattern": "/\\b[a-f0-9]{8}-[a-f0-9]{4}-[1-5][a-f0-9]{3}-[89ab][a-f0-9]{3}-[a-f0-9]{12}\\b/gi"
    }
  ],
  "overrides": [
    {
      "filename": "**/*.{html,css,js,jsx,ts,tsx}",
      "ignoreRegExpList": [
        "allCapsWords",
        "uuidLike"
      ]
    }
  ]
}